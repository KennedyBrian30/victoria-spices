          <span class="w-6 h-0.5 bg-stone-900 transition-all duration-300"
          ></span>
          <span class="w-6 h-0.5 bg-stone-900 transition-all duration-300"
          ></span>
        </button>
      </div>

      <!-- Mobile Menu -->
      <div
        id="mobile-menu"
        class="hidden md:hidden bg-white border-t border-amber-100 max-h-[calc(100vh-5rem)] overflow-y-auto transition-all duration-300 ease-in-out"
        role="dialog"
        aria-modal="true"
        aria-label="Mobile navigation"
      >
        <div class="px-6 py-8 space-y-6 text-base font-medium">
          <a href="/" class="block hover:text-amber-600 transition py-2">Home</a
          >

          <!-- Products Mobile with clickable parent -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
