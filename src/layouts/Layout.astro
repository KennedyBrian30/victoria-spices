---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = "Premium Kenyan herbs & spices exported worldwide",
  canonical = Astro.url.href,
  ogImage = "/og-image.jpg", // ← replace with real default OG image path
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.url).href} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.url).href} />

    <!-- Favicon (add your own) -->
    <!-- <link rel="icon" href="/favicon.ico" /> -->

    <!-- Google Fonts with display=swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-white text-gray-900 antialiased flex flex-col min-h-screen">
    <!-- HEADER -->
    <header
      class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-amber-100"
    >
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center"
      >
        <!-- Logo -->
        <a
          href="/"
          class="flex items-center gap-3 group focus:outline-none focus:ring-2 focus:ring-amber-500 rounded-lg"
          aria-label="Victoria Herbs & Spices home page"
        >
          <div
            class="w-10 h-10 bg-gradient-to-br from-orange-600 to-amber-500 rounded-xl flex items-center justify-center text-white font-bold text-2xl group-hover:scale-105 transition-transform"
          >
            🌿
          </div>
          <div>
            <span
              class="font-display text-2xl tracking-tight font-semibold text-stone-900"
            >
              Victoria
            </span>
            <span
              class="text-xs tracking-[0.2em] text-amber-600 block -mt-1 uppercase"
            >
              Herbs & Spices
            </span>
          </div>
        </a>

        <!-- Desktop Navigation -->
        <nav
          class="hidden md:flex items-center gap-8 text-sm font-medium"
          aria-label="Main navigation"
        >
          <a
            href="/"
            class="hover:text-amber-600 transition relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-amber-600 after:transition-all hover:after:w-full py-1 focus:outline-none focus:ring-2 focus:ring-amber-500 rounded"
          >
            Home
          </a>

          <!-- Products Dropdown with clickable parent -->
          <div class="relative group">
            <div class="flex items-center gap-1">
              <a
                href="/products"
                class="hover:text-amber-600 transition py-1 focus:outline-none focus:ring-2 focus:ring-amber-500 rounded"
              >
                Products
              </a>
              <button
                class="flex items-center hover:text-amber-600 transition py-1 focus:outline-none focus:ring-2 focus:ring-amber-500 rounded"
                aria-haspopup="true"
                aria-expanded="false"
                id="products-button"
                aria-label="Toggle products dropdown"
              >
                <svg
                  class="w-4 h-4 transition-transform group-hover:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
            </div>
            <div
              class="absolute top-full left-0 mt-2 w-48 bg-white rounded-lg shadow-xl border border-amber-100 opacity-0 scale-95 pointer-events-none group-focus-within:opacity-100 group-focus-within:scale-100 group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-200 origin-top-left z-50"
              role="menu"
              aria-labelledby="products-button"
            >
              <div class="py-2">
                <a
                  href="/products/moringa"
                  class="block px-4 py-2 hover:bg-amber-50 hover:text-amber-600 transition"
                  role="menuitem">Moringa</a
                >
                <a
                  href="/products/chilli"
                  class="block px-4 py-2 hover:bg-amber-50 hover:text-amber-600 transition"
                  role="menuitem">Chilli</a
                >
                <a
                  href="/products/hibiscus"
                  class="block px-4 py-2 hover:bg-amber-50 hover:text-amber-600 transition"
                  role="menuitem">Hibiscus</a
                >
              </div>
            </div>
          </div>

          <a
            href="/story"
            class="hover:text-amber-600 transition relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-amber-600 after:transition-all hover:after:w-full py-1 focus:outline-none focus:ring-2 focus:ring-amber-500 rounded"
          >
            Our Story
          </a>

          <!-- Global Markets Dropdown with clickable parent -->
          <div class="relative group">
            <div class="flex items-center gap-1">
              <a
                href="/markets"
                class="hover:text-amber-600 transition py-1 focus:outline-none focus:ring-2 focus:ring-amber-500 rounded"
              >
                Global Markets
              </a>
              <button
                class="flex items-center hover:text-amber-600 transition py-1 focus:outline-none focus:ring-2 focus:ring-amber-500 rounded"
                aria-haspopup="true"
                aria-expanded="false"
                id="markets-button"
                aria-label="Toggle markets dropdown"
