---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Victoria Herbs & Spices | Premium Kenyan Herbs & Spices – Exported Worldwide"
  description="Traceable, sustainably sourced Kenyan herbs and spices direct from our farms to Europe, USA, and Canada. Organic, pure, and full of flavour."
  ogImage="/chilli.jpg"
>
  <!-- HERO SECTION - More dramatic and compelling -->
  <section
    class="relative h-screen flex items-center justify-center overflow-hidden"
  >
    <!-- Background with parallax effect -->
    <div class="absolute inset-0">
      <div
        class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1596040033229-a9821ebd058d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80')] bg-cover bg-center bg-fixed"
      >
      </div>
      <div
        class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/70 to-black/90"
      >
      </div>
    </div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
      <!-- Animated badge -->
      <div
        class="inline-flex items-center gap-2 bg-amber-500/20 backdrop-blur-lg px-6 py-3 rounded-full text-amber-300 text-sm mb-8 border border-amber-500/30 animate-fade-in"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"
          ></span>
        </span>
        🌍 Direct from Kenya • Exporting to 15+ Countries
      </div>

      <h1
        class="text-5xl md:text-7xl lg:text-8xl font-display font-bold text-white leading-tight tracking-tight"
      >
        Taste the<br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-orange-400"
        >
          Heart of Kenya
        </span>
      </h1>

      <p
        class="mt-6 text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed"
      >
        From our family of farmers to your global kitchen — premium herbs and
        spices, sustainably grown, ethically sourced, and bursting with
        authentic Kenyan flavor.
      </p>

      <!-- Value proposition badges -->
      <div class="flex flex-wrap justify-center gap-4 mt-10">
        <span
          class="bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full text-white/90 text-sm border border-white/20"
        >
          🌱 100% Traceable
        </span>
        <span
          class="bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full text-white/90 text-sm border border-white/20"
        >
          ✅ ISO 22000 Certified
        </span>
        <span
          class="bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full text-white/90 text-sm border border-white/20"
        >
          ✈️ Global Shipping
        </span>
      </div>

      <div class="flex flex-col sm:flex-row gap-5 justify-center mt-12">
        <a
          href="/products"
          class="group px-10 py-5 bg-gradient-to-r from-amber-500 to-orange-500 text-white font-semibold rounded-2xl hover:from-amber-600 hover:to-orange-600 transition-all text-lg shadow-xl shadow-orange-500/20 hover:shadow-2xl hover:scale-105 focus:outline-none focus:ring-2 focus:ring-amber-400 inline-flex items-center gap-2"
        >
          Explore Our Products
          <svg
            class="w-5 h-5 group-hover:translate-x-1 transition-transform"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a
          href="/contact?quote=true"
          class="px-10 py-5 border-2 border-white/30 text-white font-semibold rounded-2xl hover:bg-white/10 hover:border-white/50 transition-all text-lg backdrop-blur-sm focus:outline-none focus:ring-2 focus:ring-white/50"
        >
          Request Export Quote
        </a>
      </div>

      <!-- Trusted by badge -->
      <div class="mt-16 text-white/50 text-sm tracking-wider">
        TRUSTED BY IMPORTERS IN
      </div>
      <div
        class="flex justify-center gap-8 mt-4 text-white/80 text-xl font-display"
      >
        <span>🇩🇪 Germany</span>
        <span>🇺🇸 USA</span>
        <span>🇨🇦 Canada</span>
        <span>🇳🇱 Netherlands</span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center text-white/40 text-xs tracking-widest"
    >
      <span>SCROLL</span>
      <div
        class="w-px h-16 bg-gradient-to-b from-transparent via-white/30 to-transparent mt-2"
      >
      </div>
    </div>
  </section>

  <!-- STATS BANNER - Social proof -->
  <div class="bg-amber-50 py-12 border-y border-amber-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl md:text-4xl font-bold text-amber-600">500+</div>
          <div class="text-sm text-stone-600 mt-2">Partner Farmers</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-amber-600">15+</div>
          <div class="text-sm text-stone-600 mt-2">Export Countries</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-amber-600">97%</div>
          <div class="text-sm text-stone-600 mt-2">Client Retention</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-amber-600">24h</div>
          <div class="text-sm text-stone-600 mt-2">Quote Response</div>
        </div>
      </div>
    </div>
  </div>

  <!-- OUR STORY - More emotional and compelling -->
  <section id="story" class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span
            class="text-amber-600 font-semibold text-sm tracking-[0.2em] uppercase"
            >Our Heritage</span
          >
          <h2
            class="text-4xl md:text-5xl font-display font-bold mt-4 leading-tight"
          >
            Crafting Excellence<br />
            <span class="text-amber-600">for Three Generations</span>
          </h2>

          <div class="space-y-6 mt-8 text-stone-700 text-lg">
            <p class="leading-relaxed">
              In the fertile highlands of Kenya, where the soil is rich and the
              sun is generous, our story began. For over 60 years, we've
              partnered with local farming families who have passed down their
              knowledge of when to harvest, how to dry, and what makes a truly
              exceptional spice.
            </p>
            <p class="leading-relaxed">
              Today, Victoria Herbs & Spices bridges this heritage with global
              demand. Every moringa leaf, every chilli, every hibiscus flower
              tells the story of Kenyan soil, Kenyan hands, and Kenyan pride —
              delivered to your market with full traceability and uncompromising
              quality.
            </p>
          </div>

          <!-- Farmer testimonial -->
          <div
            class="mt-10 p-6 bg-amber-50/50 rounded-2xl border border-amber-100"
          >
            <div class="flex items-start gap-4">
              <div class="text-5xl">👩🏾‍🌾</div>
              <div>
                <p class="text-stone-700 italic">
                  "Victoria pays fair prices and treats us as partners. My
                  children now have better schools, and our community is
                  thriving."
                </p>
                <p class="text-sm text-stone-500 mt-2">
                  — Grace Wanjiku, Smallholder Farmer, Meru
                </p>
              </div>
            </div>
          </div>

          <a
            href="/story"
            class="inline-flex items-center gap-2 mt-10 text-amber-600 hover:text-amber-700 font-semibold group"
          >
            Read Our Full Story
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <img
              src="https://images.unsplash.com/photo-1590779033100-9f60a05a013d?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80"
              alt="Kenyan farmer harvesting herbs"
              class="rounded-2xl shadow-xl w-full h-64 object-cover"
              loading="lazy"
            />
            <img
              src="https://images.unsplash.com/photo-1615485290382-441e4d049cb5?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
              alt="Fresh moringa harvest"
              class="rounded-2xl shadow-xl w-full h-48 object-cover"
              loading="lazy"
            />
          </div>
          <div class="space-y-4 mt-8">
            <img
              src="https://images.unsplash.com/photo-1596040033229-a9821ebd058d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
              alt="Sun-drying spices traditionally"
              class="rounded-2xl shadow-xl w-full h-48 object-cover"
              loading="lazy"
            />
            <img
              src="https://images.unsplash.com/photo-1629819109533-9d0fb5b6c972?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
              alt="Quality inspection"
              class="rounded-2xl shadow-xl w-full h-64 object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS - Enhanced with better copy and hover effects -->
  <section class="py-24 md:py-32 bg-gradient-to-b from-stone-50 to-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span
          class="text-amber-600 font-semibold text-sm tracking-[0.2em] uppercase"
          >Our Signature Range</span
        >
        <h2 class="text-4xl md:text-5xl font-display font-bold mt-4">
          Flagship Exports
        </h2>
        <p class="text-stone-600 text-lg mt-4">
          Hand-selected, sun-dried, and sorted to perfection — these three
          products represent the best of Kenyan agriculture, trusted by
          importers worldwide.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
        <!-- Moringa -->
        <a
          href="/products/moringa"
          class="group bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 focus:outline-none focus:ring-2 focus:ring-amber-400"
        >
          <div class="relative h-72 overflow-hidden">
            <div
              class="absolute inset-0 bg-cover bg-center group-hover:scale-110 transition-transform duration-700"
              style="background-image: url('https://images.unsplash.com/photo-1615485290382-441e4d049cb5?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80')"
            >
            </div>
            <div
              class="absolute top-4 right-4 bg-emerald-600 text-white px-4 py-2 rounded-full text-xs font-semibold"
            >
              Best Seller
            </div>
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start mb-3">
              <h3
                class="text-2xl font-bold text-stone-900 group-hover:text-amber-700 transition"
              >
                Moringa
              </h3>
              <span class="text-3xl">🌿</span>
            </div>
            <p class="text-stone-600 leading-relaxed">
              <span class="font-semibold text-amber-700"
                >The "Miracle Tree"</span
              > — our organic moringa leaf powder contains 25+ vitamins and minerals.
              Perfect for health supplements, smoothies, and functional foods.
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              <span
                class="bg-amber-50 text-amber-800 px-3 py-1 rounded-full text-xs font-medium"
                >Organic</span
              >
              <span
                class="bg-amber-50 text-amber-800 px-3 py-1 rounded-full text-xs font-medium"
                >MOQ: 500kg</span
              >
              <span
                class="bg-amber-50 text-amber-800 px-3 py-1 rounded-full text-xs font-medium"
                >High Curcumin</span
              >
            </div>
            <div
              class="mt-6 flex justify-between items-center pt-4 border-t border-stone-100"
            >
              <span class="text-sm text-stone-500">Premium Grade A</span>
              <span
                class="text-amber-600 font-medium group-hover:translate-x-2 transition-transform inline-flex items-center gap-1"
              >
                Learn More
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path>
                </svg>
              </span>
            </div>
          </div>
        </a>

        <!-- Chilli -->
        <a
          href="/products/chilli"
          class="group bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 focus:outline-none focus:ring-2 focus:ring-amber-400"
        >
          <div class="relative h-72 overflow-hidden">
            <div
              class="absolute inset-0 bg-cover bg-center group-hover:scale-110 transition-transform duration-700"
              style="background-image: url('https://images.unsplash.com/photo-1594232202007-3477c8ac1b1c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80')"
            >
            </div>
            <div
              class="absolute top-4 right-4 bg-orange-600 text-white px-4 py-2 rounded-full text-xs font-semibold"
            >
              Hot & Spicy
            </div>
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start mb-3">
              <h3
                class="text-2xl font-bold text-stone-900 group-hover:text-amber-700 transition"
              >
                African Bird's Eye Chilli
              </h3>
              <span class="text-3xl">🌶️</span>
            </div>
            <p class="text-stone-600 leading-relaxed">
              <span class="font-semibold text-amber-700"
                >80,000-100,000 SHU</span
              > — these fiery chillies are sun-dried to preserve their intense heat
              and complex flavor. Sought after by spice blenders and sauce makers
              worldwide.
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              <span
                class="bg-amber-50 text-amber-800 px-3 py-1 rounded-full text-xs font-medium"
                >Non-GMO</span
              >
              <span
                class="bg-amber-50 text-amber-800 px-3 py-1 rounded-full text-xs font-medium"
                >MOQ: 500kg</span
              >
              <span
                class="bg-amber-50 text-amber-800 px-3 py-1 rounded-full text-xs font-medium"
                >Hand-Sorted</span
              >
            </div>
            <div
              class="mt-6 flex justify-between items-center pt-4 border-t border-stone-100"
            >
              <span class="text-sm text-stone-500">Premium Grade</span>
              <span
                class="text-amber-600 font-medium group-hover:translate-x-2 transition-transform inline-flex items-center gap-1"
              >
                Learn More
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path>
                </svg>
              </span>
            </div>
          </div>
        </a>

        <!-- Hibiscus -->
        <a
          href="/products/hibiscus"
          class="group bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 focus:outline-none focus:ring-2 focus:ring-amber-400"
        >
          <div class="relative h-72 overflow-hidden">
            <div
              class="absolute inset-0 bg-cover bg-center group-hover:scale-110 transition-transform duration-700"
              style="background-image: url('https://images.unsplash.com/photo-1629819109533-9d0fb5b6c972?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80')"
            >
            </div>
            <div
              class="absolute top-4 right-4 bg-rose-600 text-white px-4 py-2 rounded-full text-xs font-semibold"
            >
              Trending
            </div>
          </div>
          <div class="p-8">
            <div class="flex justify-between items-start mb-3">
              <h3
                class="text-2xl font-bold text-stone-900 group-hover:text-amber-700 transition"
              >
                Hibiscus Flowers
              </h3>
              <span class="text-3xl">🌺</span>
            </div>
            <p class="text-stone-600 leading-relaxed">
              <span class="font-semibold text-amber-700"
                >Deep crimson calyces</span
              > with a naturally tart, cranberry-like flavor. Perfect for herbal
              teas, beverages, and natural food coloring. Grown in Kenya's highlands.
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              <span
                class="bg-amber-50 text-amber-800 px-3 py-1 rounded-full text-xs font-medium"
                >Organic</span
              >
              <span
                class="bg-amber-50 text-amber-800 px-3 py-1 rounded-full text-xs font-medium"
                >MOQ: 300kg</span
              >
              <span
                class="bg-amber-50 text-amber-800 px-3 py-1 rounded-full text-xs font-medium"
                >Dried</span
              >
            </div>
            <div
              class="mt-6 flex justify-between items-center pt-4 border-t border-stone-100"
            >
              <span class="text-sm text-stone-500">Grade A</span>
              <span
                class="text-amber-600 font-medium group-hover:translate-x-2 transition-transform inline-flex items-center gap-1"
              >
                Learn More
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path>
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>

      <div class="text-center mt-16">
        <a
          href="/products"
          class="inline-flex items-center gap-2 px-10 py-4 bg-amber-600 hover:bg-amber-700 text-white font-medium rounded-xl transition-all shadow-lg hover:shadow-xl"
        >
          Browse Complete Product Catalog
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- GLOBAL MARKETS - Interactive cards with links -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span
          class="text-amber-600 font-semibold text-sm tracking-[0.2em] uppercase"
          >Global Presence</span
        >
        <h2 class="text-4xl md:text-5xl font-display font-bold mt-4">
          Serving Markets Across Three Continents
        </h2>
        <p class="text-stone-600 text-lg mt-4">
          We've built lasting partnerships with importers, distributors, and
          food manufacturers in key markets — meeting and exceeding local
          regulatory requirements.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-10 max-w-5xl mx-auto">
        <!-- Europe Card -->
        <a
          href="/markets/europe"
          class="group relative bg-gradient-to-br from-amber-50 to-stone-50 p-8 rounded-3xl border-2 border-transparent hover:border-amber-200 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-amber-400"
        >
          <div
            class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity"
          >
            <span class="bg-amber-600 text-white text-xs px-3 py-1 rounded-full"
              >Learn More →</span
            >
          </div>
          <div
            class="text-8xl mb-6 group-hover:scale-110 transition-transform duration-300"
          >
            🇪🇺
          </div>
          <h3 class="text-2xl font-bold text-stone-900 mb-3">Europe</h3>
          <p class="text-stone-600 mb-4">
            Germany • Netherlands • UK • France • Scandinavia
          </p>
          <ul class="space-y-2 text-sm text-stone-500">
            <li class="flex items-center gap-2">
              <span class="text-emerald-600">✓</span> REACH Compliant
            </li>
            <li class="flex items-center gap-2">
              <span class="text-emerald-600">✓</span> EU Organic Certified
            </li>
            <li class="flex items-center gap-2">
              <span class="text-emerald-600">✓</span> Rotterdam Hub
            </li>
          </ul>
          <div
            class="mt-6 pt-4 border-t border-amber-200/50 flex items-center justify-between"
          >
            <span
              class="text-sm font-medium text-amber-600 group-hover:translate-x-2 transition-transform inline-flex items-center gap-1"
            >
              Market Details
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </span>
          </div>
        </a>

        <!-- USA Card -->
        <a
          href="/markets/north-america"
          class="group relative bg-gradient-to-br from-amber-50 to-stone-50 p-8 rounded-3xl border-2 border-transparent hover:border-amber-200 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-amber-400"
        >
          <div
            class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity"
          >
            <span class="bg-amber-600 text-white text-xs px-3 py-1 rounded-full"
              >Learn More →</span
            >
          </div>
          <div
            class="text-8xl mb-6 group-hover:scale-110 transition-transform duration-300"
          >
            🇺🇸
          </div>
          <h3 class="text-2xl font-bold text-stone-900 mb-3">United States</h3>
          <p class="text-stone-600 mb-4">
            FDA Approved • Major Ports: NY, LA, Savannah
          </p>
          <ul class="space-y-2 text-sm text-stone-500">
            <li class="flex items-center gap-2">
              <span class="text-emerald-600">✓</span> FDA Compliant
            </li>
            <li class="flex items-center gap-2">
              <span class="text-emerald-600">✓</span> FSMA Ready
            </li>
            <li class="flex items-center gap-2">
              <span class="text-emerald-600">✓</span> USDA Organic
            </li>
          </ul>
          <div
            class="mt-6 pt-4 border-t border-amber-200/50 flex items-center justify-between"
          >
            <span
              class="text-sm font-medium text-amber-600 group-hover:translate-x-2 transition-transform inline-flex items-center gap-1"
            >
              Market Details
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
