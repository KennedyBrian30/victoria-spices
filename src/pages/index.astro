---
// ─── NO image pipeline calls in this file ───────────────────────────────────
// All images are served straight from /public via plain <img> or CSS url().
// Unsplash serves its own CDN-optimised WebP via query params.
// This keeps build time under 10 seconds locally and under Vercel's limits.
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Victoria Agribusiness Ltd. | Premium Kenyan Herbs & Spices – Exported Worldwide"
  description="Traceable, sustainably sourced Kenyan herbs and spices direct from our farms to Europe, USA, and Canada. Organic, pure, and full of flavour."
  ogImage="/chilli.jpg"
>

  <style>
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes scroll-line {
      0%   { transform: scaleY(0); transform-origin: top; }
      50%  { transform: scaleY(1); transform-origin: top; }
      51%  { transform-origin: bottom; }
      100% { transform: scaleY(0); transform-origin: bottom; }
    }
    .animate-fade-up { animation: fade-up 0.7s ease both; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-500 { animation-delay: 0.5s; }
    .delay-700 { animation-delay: 0.7s; }
    .delay-900 { animation-delay: 0.9s; }
    .scroll-line { animation: scroll-line 2s ease-in-out infinite; }

    .grain::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1;
    }

    .stat-card:hover .stat-value { color: #d97706; transition: color 0.2s ease; }

    .product-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.06) 50%, transparent 60%);
      transform: translateX(-100%);
      transition: transform 0.6s ease;
    }
    .product-card:hover::before { transform: translateX(100%); }

    .diagonal-top    { clip-path: polygon(0 4%, 100% 0%, 100% 100%, 0% 100%); margin-top: -3%; }
    .diagonal-bottom { clip-path: polygon(0 0%, 100% 0%, 100% 96%, 0% 100%); padding-bottom: 6%; }

    .form-field:focus {
      outline: none;
      border-color: #d97706;
      box-shadow: 0 0 0 3px rgba(217,119,6,0.15);
    }
  </style>


  <!-- ═══════════════════════════════════════════ -->
  <!-- HERO                                        -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="relative h-screen min-h-[680px] flex items-center justify-center overflow-hidden grain">
    <div class="absolute inset-0">
      <!-- Unsplash CDN handles its own WebP/compression — no local processing needed -->
      <div
        class="absolute inset-0 bg-cover bg-center bg-fixed"
        style="background-image: url('https://images.unsplash.com/photo-1596040033229-a9821ebd058d?auto=format&fit=crop&w=1800&q=70&fm=webp')"
      ></div>
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/65 to-stone-950/95"></div>
      <div class="absolute inset-0 bg-gradient-to-tr from-amber-950/30 via-transparent to-transparent"></div>
    </div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
      <div class="animate-fade-up inline-flex items-center gap-2.5 bg-amber-500/15 backdrop-blur-xl px-5 py-2.5 rounded-full text-amber-300 text-sm mb-8 border border-amber-400/25 shadow-lg">
        <span aria-hidden="true" class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-400"></span>
        </span>
        <span aria-hidden="true">🌍</span> Direct from Kenya &nbsp;•&nbsp; Exporting to 15+ Countries
      </div>

      <h1 class="animate-fade-up delay-200 text-5xl md:text-7xl lg:text-8xl font-display font-bold text-white leading-[1.05] tracking-tight">
        Taste the<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-amber-400 to-orange-400">Heart of Kenya</span>
      </h1>

      <p class="animate-fade-up delay-300 mt-6 text-lg md:text-xl text-white/75 max-w-2xl mx-auto leading-relaxed font-light">
        From our family of farmers to your global kitchen — premium herbs and spices, sustainably grown, ethically sourced, and bursting with authentic Kenyan flavour.
      </p>

      <div class="animate-fade-up delay-500 flex flex-wrap justify-center gap-3 mt-9">
        <span class="bg-white/8 backdrop-blur-md px-4 py-2 rounded-full text-white/85 text-sm border border-white/15 shadow-sm"><span aria-hidden="true">🌱</span> 100% Traceable</span>
        <span class="bg-white/8 backdrop-blur-md px-4 py-2 rounded-full text-white/85 text-sm border border-white/15 shadow-sm"><span aria-hidden="true">✅</span> ISO 22000 Certified</span>
        <span class="bg-white/8 backdrop-blur-md px-4 py-2 rounded-full text-white/85 text-sm border border-white/15 shadow-sm"><span aria-hidden="true">✈️</span> Global Shipping</span>
      </div>

      <div class="animate-fade-up delay-700 flex flex-col sm:flex-row gap-4 justify-center mt-11">
        <a href="/products" class="group px-9 py-4 bg-gradient-to-r from-amber-500 to-orange-500 text-white font-semibold rounded-2xl hover:from-amber-400 hover:to-orange-400 transition-all text-base shadow-xl shadow-orange-600/25 hover:-translate-y-0.5 inline-flex items-center justify-center gap-2">
          Explore Our Products
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#contact" class="px-9 py-4 border border-white/25 text-white font-medium rounded-2xl hover:bg-white/8 hover:border-white/40 transition-all text-base backdrop-blur-sm inline-flex items-center justify-center">
          Request Export Quote
        </a>
      </div>

      <div class="animate-fade-up delay-900 mt-14">
        <p class="text-white/35 text-[11px] tracking-[0.25em] uppercase mb-3">Trusted by importers in</p>
        <div class="flex justify-center gap-6 text-white/70 text-base font-medium">
          <span><span aria-hidden="true">🇩🇪</span> Germany</span>
          <span><span aria-hidden="true">🇺🇸</span> USA</span>
          <span><span aria-hidden="true">🇨🇦</span> Canada</span>
          <span><span aria-hidden="true">🇳🇱</span> Netherlands</span>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30 text-[10px] tracking-[0.3em]" aria-hidden="true">
      <span>SCROLL</span>
      <div class="w-px h-12 bg-gradient-to-b from-white/30 to-transparent scroll-line"></div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- STATS BANNER                                -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="bg-amber-600 py-10">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="stat-card group cursor-default">
          <div class="stat-value text-3xl md:text-4xl font-bold text-white group-hover:scale-110 transition-transform duration-200">1,360+</div>
          <div class="text-amber-100/80 text-sm mt-1.5 font-medium">Partner Farmers</div>
        </div>
        <div class="stat-card group cursor-default">
          <div class="stat-value text-3xl md:text-4xl font-bold text-white group-hover:scale-110 transition-transform duration-200">15+</div>
          <div class="text-amber-100/80 text-sm mt-1.5 font-medium">Export Countries</div>
        </div>
        <div class="stat-card group cursor-default">
          <div class="stat-value text-3xl md:text-4xl font-bold text-white group-hover:scale-110 transition-transform duration-200">97%</div>
          <div class="text-amber-100/80 text-sm mt-1.5 font-medium">Client Retention</div>
        </div>
        <div class="stat-card group cursor-default">
          <div class="stat-value text-3xl md:text-4xl font-bold text-white group-hover:scale-110 transition-transform duration-200">24h</div>
          <div class="text-amber-100/80 text-sm mt-1.5 font-medium">Quote Response</div>
        </div>
      </div>
    </div>
  </div>


  <!-- ═══════════════════════════════════════════ -->
  <!-- OUR STORY                                   -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="story" class="py-28 md:py-36 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl">
        <span class="text-amber-600 font-semibold text-xs tracking-[0.3em] uppercase">Our Heritage</span>
        <h2 class="text-4xl md:text-5xl font-display font-bold mt-4 leading-tight text-stone-900">
          Crafting Excellence<br />
          <span class="text-amber-600">for Three Generations</span>
        </h2>

        <div class="space-y-5 mt-8 text-stone-600 text-lg leading-relaxed">
          <p>In the fertile highlands of Kenya, our story began. The soils are rich and generous, and for over 60 years, we've partnered with local farming families who have passed down their knowledge — of when to harvest, how to dry, and what makes a truly exceptional spice.</p>
          <p>Today, Victoria Agribusiness Ltd. bridges this heritage with global demand. Every moringa leaf, every chilli, every hibiscus flower tells the story of Kenyan soil, Kenyan hands, and Kenyan pride — delivered to your market with full traceability and uncompromising quality.</p>
        </div>

        <div class="flex items-center gap-4 mt-10 mb-10">
          <div class="h-px flex-1 bg-amber-100"></div>
          <span aria-hidden="true" class="text-amber-400 text-lg">✦</span>
          <div class="h-px flex-1 bg-amber-100"></div>
        </div>

        <blockquote class="pl-6 border-l-4 border-amber-400">
          <p class="text-stone-700 text-xl italic leading-relaxed font-light">
            "Victoria pays fair prices and treats us as partners. My children now have better schools, and our community is thriving."
          </p>
          <footer class="mt-4 flex items-center gap-3">
            <span aria-hidden="true" class="text-2xl">👩🏾‍🌾</span>
            <cite class="not-italic text-sm text-stone-400 font-medium">Grace Wanjiku — Smallholder Moringa Farmer, Meru, Kenya</cite>
          </footer>
        </blockquote>

        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mt-10">
          <a href="/story" class="inline-flex items-center gap-2 text-amber-600 hover:text-amber-700 font-semibold group text-base">
            Read Our Full Story
            <svg class="w-4 h-4 group-hover:translate-x-1.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#contact" class="inline-flex items-center gap-2 bg-amber-600 hover:bg-amber-700 text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-all shadow-sm hover:shadow-md">
            <span aria-hidden="true">📩</span> Request a Quote
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- FARMER SECTION                              -->
  <!-- Plain <img> — no Astro pipeline             -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-20 md:py-24 bg-stone-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <div class="relative">
          <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl">
            <img
              src="/farmer.jpg"
              alt="Kenyan smallholder farmer working in the field"
              class="w-full h-full object-cover"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
          <div class="absolute -bottom-5 -right-4 sm:right-8 bg-amber-600 text-white px-6 py-4 rounded-2xl shadow-xl shadow-amber-700/30">
            <div class="text-3xl font-bold leading-none">1,360</div>
            <div class="text-amber-100 text-xs mt-1 font-medium tracking-wide">Partner Farmers</div>
          </div>
        </div>

        <div>
          <span class="text-amber-600 font-semibold text-xs tracking-[0.3em] uppercase">Our Farming Community</span>
          <h2 class="text-3xl md:text-4xl font-display font-bold mt-4 leading-tight text-stone-900">
            From Smallholder Farmers<br />
            <span class="text-amber-600">to Global Markets</span>
          </h2>
          <p class="mt-6 text-stone-600 text-lg leading-relaxed">
            We work hand-in-hand with <strong class="text-stone-800 font-semibold">1,360 smallholder farmers</strong> spread across Kenya's diverse growing regions — from the highlands of Meru to the fertile plains of the Rift Valley.
          </p>
          <p class="mt-4 text-stone-500 leading-relaxed">
            Our produce reaches <strong class="text-stone-700 font-medium">local supermarkets</strong> and <strong class="text-stone-700 font-medium">hotels</strong> across Kenya, as well as <strong class="text-stone-700 font-medium">global markets</strong> in Europe, Asia, and North America.
          </p>

          <div class="grid grid-cols-3 gap-4 mt-10">
            <div class="text-center p-4 bg-white rounded-2xl border border-stone-100 shadow-sm">
              <div aria-hidden="true" class="text-3xl mb-2">🏪</div>
              <div class="text-xs text-stone-500 font-medium leading-snug">Local Supermarkets</div>
            </div>
            <div class="text-center p-4 bg-white rounded-2xl border border-stone-100 shadow-sm">
              <div aria-hidden="true" class="text-3xl mb-2">🏨</div>
              <div class="text-xs text-stone-500 font-medium leading-snug">Hotels & Hospitality</div>
            </div>
            <div class="text-center p-4 bg-white rounded-2xl border border-stone-100 shadow-sm">
              <div aria-hidden="true" class="text-3xl mb-2">✈️</div>
              <div class="text-xs text-stone-500 font-medium leading-snug">Global Export</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- FEATURED PRODUCTS                           -->
  <!-- CSS bg-image from /public — no pipeline     -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="diagonal-top diagonal-bottom py-24 md:py-32 bg-gradient-to-b from-stone-50 to-amber-50/30">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-amber-600 font-semibold text-xs tracking-[0.3em] uppercase">Our Signature Range</span>
        <h2 class="text-4xl md:text-5xl font-display font-bold mt-4 text-stone-900">Flagship Exports</h2>
        <p class="text-stone-500 text-lg mt-4 leading-relaxed">Hand-selected, sun-dried, and sorted to perfection — trusted by importers worldwide.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">

        <!-- Moringa -->
        <a href="/products/moringa"
          aria-label="Moringa — Premium Grade A organic leaf powder. View product details."
          class="product-card group relative bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 focus:outline-none focus:ring-2 focus:ring-amber-400">
          <div class="relative h-64 overflow-hidden">
            <div class="absolute inset-0 bg-cover bg-center group-hover:scale-105 transition-transform duration-700" style="background-image: url('/moringa.jpg')"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <span class="absolute top-4 right-4 bg-emerald-500 text-white px-3 py-1 rounded-full text-xs font-semibold shadow-lg">Best Seller</span>
          </div>
          <div class="p-7">
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-xl font-bold text-stone-900 group-hover:text-amber-700 transition-colors">Moringa</h3>
              <span aria-hidden="true" class="text-2xl">🌿</span>
            </div>
            <p class="text-stone-500 text-sm leading-relaxed">
              <span class="font-semibold text-amber-600">The "Miracle Tree"</span> — organic leaf powder with 25+ vitamins and minerals. Perfect for supplements, smoothies, and functional foods.
            </p>
            <div class="mt-5 flex flex-wrap gap-1.5">
              <span class="bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-1 rounded-full text-xs font-medium">Organic</span>
              <span class="bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-1 rounded-full text-xs font-medium">MOQ: 500kg</span>
              <span class="bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-1 rounded-full text-xs font-medium">High Curcumin</span>
            </div>
            <div class="mt-5 flex justify-between items-center pt-4 border-t border-stone-100">
              <span class="text-xs text-stone-400 font-medium uppercase tracking-wider">Premium Grade A</span>
              <span aria-hidden="true" class="text-amber-600 font-medium group-hover:translate-x-1.5 transition-transform inline-flex items-center gap-1 text-sm">
                Learn More <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>

        <!-- Chilli -->
        <a href="/products/chilli"
          aria-label="African Bird's Eye Chilli — Premium Grade, 80,000–100,000 SHU. View product details."
          class="product-card group relative bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 focus:outline-none focus:ring-2 focus:ring-amber-400">
          <div class="relative h-64 overflow-hidden">
            <div class="absolute inset-0 bg-cover bg-center group-hover:scale-105 transition-transform duration-700" style="background-image: url('/chilli.jpg')"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <span class="absolute top-4 right-4 bg-orange-500 text-white px-3 py-1 rounded-full text-xs font-semibold shadow-lg">Hot & Spicy</span>
          </div>
          <div class="p-7">
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-xl font-bold text-stone-900 group-hover:text-amber-700 transition-colors">African Bird's Eye Chilli</h3>
              <span aria-hidden="true" class="text-2xl">🌶️</span>
            </div>
            <p class="text-stone-500 text-sm leading-relaxed">
              <span class="font-semibold text-amber-600">80,000–100,000 SHU</span> — sun-dried to preserve intense heat and complex flavour. Sought after by spice blenders and sauce makers worldwide.
            </p>
            <div class="mt-5 flex flex-wrap gap-1.5">
              <span class="bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-1 rounded-full text-xs font-medium">Non-GMO</span>
              <span class="bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-1 rounded-full text-xs font-medium">MOQ: 500kg</span>
              <span class="bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-1 rounded-full text-xs font-medium">Hand-Sorted</span>
            </div>
            <div class="mt-5 flex justify-between items-center pt-4 border-t border-stone-100">
              <span class="text-xs text-stone-400 font-medium uppercase tracking-wider">Premium Grade</span>
              <span aria-hidden="true" class="text-amber-600 font-medium group-hover:translate-x-1.5 transition-transform inline-flex items-center gap-1 text-sm">
                Learn More <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>

        <!-- Hibiscus -->
        <a href="/products/hibiscus"
          aria-label="Hibiscus Flowers — Grade A dried calyces for teas and beverages. View product details."
          class="product-card group relative bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 focus:outline-none focus:ring-2 focus:ring-amber-400">
          <div class="relative h-64 overflow-hidden">
            <div class="absolute inset-0 bg-cover bg-center group-hover:scale-105 transition-transform duration-700" style="background-image: url('/hibiscus.jpg')"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <span class="absolute top-4 right-4 bg-rose-500 text-white px-3 py-1 rounded-full text-xs font-semibold shadow-lg">Trending</span>
          </div>
          <div class="p-7">
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-xl font-bold text-stone-900 group-hover:text-amber-700 transition-colors">Hibiscus Flowers</h3>
              <span aria-hidden="true" class="text-2xl">🌺</span>
            </div>
            <p class="text-stone-500 text-sm leading-relaxed">
              <span class="font-semibold text-amber-600">Deep crimson calyces</span> with a naturally tart, cranberry-like flavour. Ideal for herbal teas, beverages, and natural food colouring.
            </p>
            <div class="mt-5 flex flex-wrap gap-1.5">
              <span class="bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-1 rounded-full text-xs font-medium">Organic</span>
              <span class="bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-1 rounded-full text-xs font-medium">MOQ: 300kg</span>
              <span class="bg-amber-50 text-amber-700 border border-amber-100 px-2.5 py-1 rounded-full text-xs font-medium">Dried</span>
            </div>
            <div class="mt-5 flex justify-between items-center pt-4 border-t border-stone-100">
              <span class="text-xs text-stone-400 font-medium uppercase tracking-wider">Grade A</span>
              <span aria-hidden="true" class="text-amber-600 font-medium group-hover:translate-x-1.5 transition-transform inline-flex items-center gap-1 text-sm">
                Learn More <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>

      </div>

      <div class="text-center mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/products" class="inline-flex items-center gap-2 px-9 py-4 bg-stone-900 hover:bg-amber-600 text-white font-medium rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Browse Complete Catalog
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#contact" class="inline-flex items-center gap-2 px-9 py-4 border-2 border-amber-500 text-amber-700 hover:bg-amber-50 font-medium rounded-xl transition-all duration-200">
          Request Samples
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
      </div>
