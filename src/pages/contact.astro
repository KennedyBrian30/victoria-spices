---
import Layout from "../layouts/Layout.astro";

// Get query parameters for pre-filled forms (if any)
const quote = Astro.url.searchParams.get("quote");
const samples = Astro.url.searchParams.get("samples");
const product = Astro.url.searchParams.get("product") || "";
const bulk = Astro.url.searchParams.get("bulk");
---

<Layout
  title="Contact Us | Victoria Herbs & Spices – Export Inquiries & Sample Requests"
  description="Contact Victoria Herbs & Spices for export inquiries, sample requests, and bulk orders. Our team responds within 24 hours. Nairobi, Kenya."
>
  <!-- Hero Section -->
  <section
    class="relative py-32 bg-gradient-to-br from-stone-900 to-amber-900 text-white overflow-hidden"
  >
    <div class="absolute inset-0 opacity-10">
      <div
        class="absolute inset-0"
        style="background-image: url('https://images.unsplash.com/photo-1596040033229-a9821ebd058d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80'); background-size: cover; background-position: center;"
      >
      </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 text-center">
      <div
        class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full text-amber-300 text-sm mb-6 border border-white/20"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"
          ></span>
        </span>
        📞 24-Hour Response Guarantee
      </div>

      <h1 class="text-5xl md:text-6xl font-display font-bold mb-6">
        Let's Talk Business
      </h1>
      <p class="text-xl text-white/80 max-w-3xl mx-auto">
        Whether you need samples, specifications, or a container quote — our
        export team is ready to help.
      </p>

      <!-- Quick Response Stats -->
      <div class="flex flex-wrap justify-center gap-8 mt-12">
        <div class="text-center">
          <div class="text-3xl font-bold text-amber-400">⏱️ 24h</div>
          <div class="text-sm text-white/60">Quote Response</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-amber-400">📋 48h</div>
          <div class="text-sm text-white/60">Sample Dispatch</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-amber-400">🌍 15+</div>
          <div class="text-sm text-white/60">Countries Served</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Contact Options -->
  <section class="py-16 bg-white border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Email -->
        <a
          href="mailto:export@victoriaherbs.co.ke"
          class="group flex items-center gap-4 p-6 bg-stone-50 hover:bg-amber-50 rounded-2xl transition border border-stone-200 hover:border-amber-300"
        >
          <div
            class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center text-2xl group-hover:scale-110 transition"
          >
            📧
          </div>
          <div>
            <div class="text-sm text-stone-500">Email Us</div>
            <div class="font-medium text-stone-900 group-hover:text-amber-700">
              export@victoriaherbs.co.ke
            </div>
          </div>
        </a>

        <!-- Phone -->
        <a
          href="tel:+254700000000"
          class="group flex items-center gap-4 p-6 bg-stone-50 hover:bg-amber-50 rounded-2xl transition border border-stone-200 hover:border-amber-300"
        >
          <div
            class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center text-2xl group-hover:scale-110 transition"
          >
            📞
          </div>
          <div>
            <div class="text-sm text-stone-500">Call Us</div>
            <div class="font-medium text-stone-900 group-hover:text-amber-700">
              +254 700 000 000
            </div>
          </div>
        </a>

        <!-- WhatsApp -->
        <a
          href="https://wa.me/254700000000"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 p-6 bg-stone-50 hover:bg-green-50 rounded-2xl transition border border-stone-200 hover:border-green-300"
        >
          <div
            class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-2xl group-hover:scale-110 transition"
          >
            💬
          </div>
          <div>
            <div class="text-sm text-stone-500">WhatsApp</div>
            <div class="font-medium text-stone-900 group-hover:text-green-700">
              +254 700 000 000
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Main Contact Section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Contact Form -->
        <div>
          <span
            class="text-amber-600 font-semibold text-sm tracking-[0.2em] uppercase"
            >Get in Touch</span
          >
          <h2
            class="text-4xl md:text-5xl font-display font-bold mt-4 text-stone-900"
          >
            Send Us an Inquiry
          </h2>
          <p class="text-stone-600 text-lg mt-4">
            Tell us about your needs, and we'll get back to you within 24 hours
            with pricing, specifications, and next steps.
          </p>

          <form
            class="mt-10 space-y-6"
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
          >
            <!-- Inquiry Type (pre-filled from URL params) -->
            <div class="grid grid-cols-3 gap-3">
              <label
                class={`flex-1 cursor-pointer ${quote === "true" ? "ring-2 ring-amber-500" : ""}`}
              >
                <input
                  type="radio"
                  name="inquiryType"
                  value="quote"
                  class="hidden"
                  checked={quote === "true"}
                />
                <div
                  class={`text-center p-4 rounded-xl border-2 transition ${quote === "true" ? "border-amber-500 bg-amber-50" : "border-stone-200 hover:border-amber-300"}`}
                >
                  <span class="block text-2xl mb-2">💰</span>
                  <span class="font-medium">Request Quote</span>
                </div>
              </label>

              <label
                class={`flex-1 cursor-pointer ${samples === "true" ? "ring-2 ring-amber-500" : ""}`}
              >
                <input
                  type="radio"
                  name="inquiryType"
                  value="samples"
                  class="hidden"
                  checked={samples === "true"}
                />
                <div
                  class={`text-center p-4 rounded-xl border-2 transition ${samples === "true" ? "border-amber-500 bg-amber-50" : "border-stone-200 hover:border-amber-300"}`}
                >
                  <span class="block text-2xl mb-2">🔬</span>
                  <span class="font-medium">Order Samples</span>
                </div>
              </label>

              <label
                class={`flex-1 cursor-pointer ${bulk === "true" ? "ring-2 ring-amber-500" : ""}`}
              >
                <input
                  type="radio"
                  name="inquiryType"
                  value="bulk"
                  class="hidden"
                  checked={bulk === "true"}
                />
                <div
                  class={`text-center p-4 rounded-xl border-2 transition ${bulk === "true" ? "border-amber-500 bg-amber-50" : "border-stone-200 hover:border-amber-300"}`}
                >
                  <span class="block text-2xl mb-2">📦</span>
                  <span class="font-medium">Bulk Order</span>
                </div>
              </label>
            </div>

            <!-- Name -->
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-2"
                >Full Name *</label
              >
              <input
                type="text"
                name="name"
                required
                class="w-full px-6 py-4 rounded-xl border border-stone-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition"
                placeholder="John Doe"
              />
            </div>

            <!-- Company -->
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-2"
                >Company Name *</label
              >
              <input
                type="text"
                name="company"
                required
                class="w-full px-6 py-4 rounded-xl border border-stone-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition"
                placeholder="Your Company Ltd."
              />
            </div>

            <!-- Email & Phone Grid -->
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-stone-700 mb-2"
                  >Business Email *</label
                >
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full px-6 py-4 rounded-xl border border-stone-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition"
                  placeholder="you@company.com"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-stone-700 mb-2"
                  >Phone Number *</label
                >
                <input
                  type="tel"
                  name="phone"
                  required
                  class="w-full px-6 py-4 rounded-xl border border-stone-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition"
                  placeholder="+254 700 000 000"
                />
              </div>
            </div>

            <!-- Country & Product Grid -->
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-stone-700 mb-2"
                  >Country / Market *</label
                >
                <select
                  name="country"
                  required
                  class="w-full px-6 py-4 rounded-xl border border-stone-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition bg-white"
                >
                  <option value="">Select your market</option>
                  <option value="europe">Europe</option>
                  <option value="usa">United States</option>
                  <option value="canada">Canada</option>
                  <option value="asia">Asia</option>
                  <option value="middle-east">Middle East</option>
                  <option value="africa">Africa</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-stone-700 mb-2"
                  >Product Interest *</label
                >
                <select
                  name="product"
                  required
                  class="w-full px-6 py-4 rounded-xl border border-stone-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition bg-white"
                >
                  <option value="">Select product</option>
                  <option
                    value="moringa"
                    selected={product === "moringa" ||
                      product.includes("Moringa")}>Moringa</option
                  >
                  <option
                    value="chilli"
                    selected={product === "chilli" ||
                      product.includes("Chilli")}>Chilli</option
                  >
                  <option
                    value="hibiscus"
                    selected={product === "hibiscus" ||
                      product.includes("Hibiscus")}>Hibiscus</option
                  >
                  <option value="multiple">Multiple Products</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>

            <!-- Quantity & Packaging -->
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-stone-700 mb-2"
                  >Estimated Quantity *</label
                >
                <select
                  name="quantity"
                  required
                  class="w-full px-6 py-4 rounded-xl border border-stone-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition bg-white"
                >
                  <option value="">Select quantity</option>
                  <option value="sample">Sample only (1-5kg)</option>
                  <option value="small">Small (25-100kg)</option>
                  <option value="medium">Medium (100-500kg)</option>
                  <option value="large">Large (500-1000kg)</option>
                  <option value="container">Full Container (10-25MT)</option>
                  <option value="multiple">Multiple Containers</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-stone-700 mb-2"
                  >Packaging Preference</label
                >
                <select
                  name="packaging"
                  class="w-full px-6 py-4 rounded-xl border border-stone-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition bg-white"
                >
                  <option value="">Select preference</option>
                  <option value="standard">Standard export bags (25kg)</option>
                  <option value="vacuum">Vacuum sealed</option>
                  <option value="retail">Retail-ready packaging</option>
                  <option value="custom">Custom packaging</option>
                </select>
              </div>
            </div>

            <!-- Message -->
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-2"
                >Additional Information</label
              >
              <textarea
                name="message"
                rows="5"
                class="w-full px-6 py-4 rounded-xl border border-stone-200 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition"
                placeholder="Tell us about your specific requirements, certifications needed, timeline, etc."
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              class="w-full bg-amber-600 hover:bg-amber-700 text-white font-semibold py-5 px-6 rounded-xl transition shadow-lg hover:shadow-xl"
            >
              Send Inquiry
            </button>

            <p class="text-xs text-stone-400 text-center mt-4">
              By submitting this form, you agree to our privacy policy and
              consent to being contacted by our export team.
            </p>
          </form>
        </div>

        <!-- Contact Information Sidebar -->
        <div>
          <!-- Nairobi Office -->
          <div class="bg-stone-50 p-8 rounded-3xl mb-8">
            <div class="flex items-center gap-3 mb-6">
              <div
                class="w-12 h-12 bg-amber-600 rounded-xl flex items-center justify-center text-white text-2xl"
              >
                🇰🇪
              </div>
              <h3 class="text-2xl font-bold text-stone-900">
                Nairobi Headquarters
              </h3>
            </div>

            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <span class="text-amber-600 text-xl">📍</span>
                <div>
                  <p class="font-medium text-stone-900">
                    Victoria Herbs & Spices Ltd.
                  </p>
                  <p class="text-stone-600">
                    Kiambu Road, 4th Floor<br />Nairobi, Kenya 00100
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <span class="text-amber-600 text-xl">📧</span>
                <div>
                  <p class="font-medium text-stone-900">Email</p>
                  <a
                    href="mailto:export@victoriaherbs.co.ke"
                    class="text-stone-600 hover:text-amber-600"
                    >export@victoriaherbs.co.ke</a
                  >
                </div>
              </div>

              <div class="flex items-start gap-3">
                <span class="text-amber-600 text-xl">📞</span>
                <div>
                  <p class="font-medium text-stone-900">Phone</p>
                  <a
                    href="tel:+254700000000"
                    class="text-stone-600 hover:text-amber-600"
                    >+254 700 000 000</a
                  >
                  <p class="text-xs text-stone-500 mt-1">
                    Mon-Fri, 8:00 AM - 5:00 PM EAT
                  </p>
                </div>
              </div>
            </div>

            <!-- Map Placeholder -->
            <div class="mt-6 bg-stone-200 h-48 rounded-xl overflow-hidden">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3988.8462962765316!2d36.821946!3d-1.292066!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x182f10d2b7f1d8a5%3A0x3b3c9d8f5d9c9b8!2sNairobi!5e0!3m2!1sen!2ske!4v1620000000000!5m2!1sen!2ske"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                title="Victoria Herbs Nairobi Office Location"></iframe>
            </div>
          </div>

          <!-- Export Team -->
          <div class="bg-amber-50 p-8 rounded-3xl mb-8 border border-amber-200">
            <h3 class="text-2xl font-bold text-stone-900 mb-6">
              Direct Export Team
            </h3>

            <div class="space-y-4">
              <div class="flex items-center gap-4">
                <div
                  class="w-12 h-12 bg-amber-200 rounded-full flex items-center justify-center text-xl"
                >
                  👩🏾
                </div>
                <div>
                  <p class="font-bold text-stone-900">Victoria Wanjiku</p>
                  <p class="text-sm text-stone-600">
                    Founder & Export Director
                  </p>
                  <a
                    href="mailto:victoria@victoriaherbs.co.ke"
                    class="text-sm text-amber-600 hover:underline"
                    >victoria@victoriaherbs.co.ke</a
                  >
                </div>
              </div>

              <div class="flex items-center gap-4">
                <div
                  class="w-12 h-12 bg-amber-200 rounded-full flex items-center justify-center text-xl"
                >
                  👨🏾
                </div>
                <div>
                  <p class="font-bold text-stone-900">James Omondi</p>
                  <p class="text-sm text-stone-600">Export Sales Manager</p>
                  <a
                    href="mailto:james@victoriaherbs.co.ke"
                    class="text-sm text-amber-600 hover:underline"
                    >james@victoriaherbs.co.ke</a
                  >
                </div>
              </div>

              <div class="flex items-center gap-4">
                <div
                  class="w-12 h-12 bg-amber-200 rounded-full flex items-center justify-center text-xl"
                >
                  👩🏾
                </div>
                <div>
                  <p class="font-bold text-stone-900">Mary Kimani</p>
                  <p class="text-sm text-stone-600">Quality & Compliance</p>
                  <a
                    href="mailto:quality@victoriaherbs.co.ke"
                    class="text-sm text-amber-600 hover:underline"
                    >quality@victoriaherbs.co.ke</a
                  >
                </div>
              </div>
            </div>
          </div>

          <!-- Quick Reference -->
          <div class="bg-stone-50 p-8 rounded-3xl">
            <h3 class="text-2xl font-bold text-stone-900 mb-6">
              Quick Reference
            </h3>

            <div class="space-y-4">
              <div class="flex justify-between py-2 border-b border-stone-200">
                <span class="text-stone-600">Export Documentation</span>
                <span class="font-medium text-stone-900">Included</span>
              </div>
              <div class="flex justify-between py-2 border-b border-stone-200">
                <span class="text-stone-600">Sample Policy</span>
                <span class="font-medium text-stone-900"
                  >Available (fee applies)</span
                >
              </div>
              <div class="flex justify-between py-2 border-b border-stone-200">
                <span class="text-stone-600">MOQ</span>
                <span class="font-medium text-stone-900">25kg per product</span>
              </div>
              <div class="flex justify-between py-2 border-b border-stone-200">
                <span class="text-stone-600">Payment Terms</span>
                <span class="font-medium text-stone-900">T/T, L/C</span>
              </div>
              <div class="flex justify-between py-2 border-b border-stone-200">
                <span class="text-stone-600">Shipping Terms</span>
                <span class="font-medium text-stone-900">FOB Mombasa, CIF</span>
              </div>
              <div class="flex justify-between py-2">
                <span class="text-stone-600">Response Time</span>
                <span class="font-medium text-amber-600">24 hours</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-24 bg-stone-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span
          class="text-amber-600 font-semibold text-sm tracking-[0.2em] uppercase"
          >FAQ</span
        >
        <h2
          class="text-4xl md:text-5xl font-display font-bold mt-4 text-stone-900"
        >
          Frequently Asked Questions
        </h2>
        <p class="text-stone-600 text-lg mt-4">
          Quick answers to common questions about ordering, samples, and
          shipping.
        </p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white p-6 rounded-2xl border border-stone-200">
          <summary
            class="flex justify-between items-center cursor-pointer list-none"
          >
            <h3 class="text-lg font-bold text-stone-900">
              What are your minimum order quantities (MOQ)?
            </h3>
            <span class="text-amber-600 group-open:rotate-180 transition"
              >▼</span
            >
          </summary>
          <p class="mt-4 text-stone-600">
            Our standard MOQ is 25kg per product for export orders. For sample
            orders, we offer 500g-1kg packages at a nominal fee plus shipping.
            We understand that new relationships start small — contact us to
            discuss your specific needs.
          </p>
        </details>

        <details class="group bg-white p-6 rounded-2xl border border-stone-200">
          <summary
            class="flex justify-between items-center cursor-pointer list-none"
          >
            <h3 class="text-lg font-bold text-stone-900">
              How do I request samples?
            </h3>
            <span class="text-amber-600 group-open:rotate-180 transition"
              >▼</span
            >
          </summary>
          <p class="mt-4 text-stone-600">
            Use the form above and select "Order Samples" as your inquiry type,
            or email us directly at samples@victoriaherbs.co.ke. Samples are
            typically dispatched within 48 hours of payment confirmation. Sample
            cost is deducted from your first order.
          </p>
        </details>

        <details class="group bg-white p-6 rounded-2xl border border-stone-200">
          <summary
            class="flex justify-between items-center cursor-pointer list-none"
          >
            <h3 class="text-lg font-bold text-stone-900">
              What documentation do you provide?
            </h3>
            <span class="text-amber-600 group-open:rotate-180 transition"
              >▼</span
            >
          </summary>
          <p class="mt-4 text-stone-600">
            Every shipment includes: Commercial Invoice, Packing List,
            Certificate of Origin, Phytosanitary Certificate, Bill of Lading,
            and Certificate of Analysis. Additional documentation (EUR.1, FDA
            Prior Notice, Organic Certificates, etc.) available on request.
          </p>
        </details>

        <details class="group bg-white p-6 rounded-2xl border border-stone-200">
          <summary
            class="flex justify-between items-center cursor-pointer list-none"
          >
            <h3 class="text-lg font-bold text-stone-900">
              How long does shipping take?
            </h3>
            <span class="text-amber-600 group-open:rotate-180 transition"
              >▼</span
            >
          </summary>
          <p class="mt-4 text-stone-600">
            Transit times from Mombasa: Europe 22-28 days, US East Coast 25-32
            days, US West Coast 28-35 days, Asia 25-35 days. We can also arrange
            air freight for urgent orders (3-5 days).
          </p>
        </details>

        <details class="group bg-white p-6 rounded-2xl border border-stone-200">
          <summary
            class="flex justify-between items-center cursor-pointer list-none"
          >
            <h3 class="text-lg font-bold text-stone-900">
              Do you offer custom packaging?
            </h3>
            <span class="text-amber-600 group-open:rotate-180 transition"
              >▼</span
            >
          </summary>
          <p class="mt-4 text-stone-600">
            Yes, for container orders we can accommodate custom packaging
            including private labeling, specific bag sizes, and retail-ready
            packaging. Minimum quantities apply — please discuss your
            requirements with our team.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Why Work With Us -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-display font-bold text-stone-900">
          Why Importers Choose Victoria
        </h2>
      </div>

      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center">
